{
  "name": "frostwig-voice",
  "displayName": "Frostwig Voice - Talk to Your Claude Code Buddy",
  "description": "Give your Claude Code buddy a voice in VS Code. Detects buddy speech locally and speaks it with macOS TTS.",
  "version": "1.0.0",
  "publisher": "execlayer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BMC-INC/buddy-voice.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/BMC-INC/buddy-voice/tree/main/packages/vscode",
  "bugs": {
    "url": "https://github.com/BMC-INC/buddy-voice/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Productivity"],
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "tts",
    "text-to-speech",
    "voice",
    "terminal",
    "pet",
    "companion",
    "macos",
    "developer-tools"
  ],
  "activationEvents": [
    "onDidOpenTerminal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "frostwig.toggleVoice",
        "title": "Frostwig: Toggle Voice"
      },
      {
        "command": "frostwig.changeVoice",
        "title": "Frostwig: Change Voice"
      },
      {
        "command": "frostwig.testVoice",
        "title": "Frostwig: Test Voice"
      },
      {
        "command": "frostwig.showStats",
        "title": "Frostwig: Show Buddy Stats"
      },
      {
        "command": "frostwig.mute",
        "title": "Frostwig: Mute"
      },
      {
        "command": "frostwig.unmute",
        "title": "Frostwig: Unmute"
      }
    ],
    "configuration": {
      "title": "Frostwig Voice",
      "properties": {
        "frostwig.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Frostwig voice output"
        },
        "frostwig.voice": {
          "type": "string",
          "default": "Daniel",
          "description": "macOS voice name for TTS"
        },
        "frostwig.rate": {
          "type": "number",
          "default": 180,
          "description": "Speech rate (words per minute)"
        },
        "frostwig.volume": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Reserved for future voice backends. The native macOS say command does not expose per-call volume."
        },
        "frostwig.muteOnFocus": {
          "type": "boolean",
          "default": false,
          "description": "Only speak when terminal is focused"
        },
        "frostwig.buddyName": {
          "type": "string",
          "default": "",
          "description": "Override buddy name detection (leave empty for auto-detect)"
        },
        "frostwig.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notification with bubble text"
        },
        "frostwig.soundEffect": {
          "type": "boolean",
          "default": true,
          "description": "Reserved for future voice polish. No chirp is currently played by the extension."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
